PIXABAY_API_KEY=
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=.railway.app,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://*.railway.app
CORS_ALLOWED_ORIGINS=
MEDIA_ROOT=/app/backend/media
SUBTITLE_FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc

# MySQL is the default database. Keep production credentials outside Git.
DB_ENGINE=mysql
DB_NAME=videomaker
DB_USER=videomaker
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=3306
DB_CONN_MAX_AGE=60

# Use this only when exporting data from the old local SQLite database.
# DB_ENGINE=sqlite
